# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# ---- Required ----------------------------------------------------------------

# Discord bot token from https://discord.com/developers/applications
# Bot tab → Reset Token → copy the value here.
DISCORD_BOT_TOKEN=

# PostgreSQL connection string. Must point at the same database as the
# nexusexporter-clean web app — the bot reads its tables for league data.
# Examples:
#   postgresql://nexus:nexus@localhost:5433/nexus       (local docker-compose)
#   postgresql://user:pass@host.railway.internal:5432/db (Railway)
DATABASE_URL=

# ---- Optional ----------------------------------------------------------------

# Comma-separated Discord guild IDs. When set, slash commands sync to those
# guilds instantly on startup (good for development). When empty, sync is
# global and can take up to ~1 hour to propagate.
GUILD_IDS=

# OpenAI integration for /headline and AI-generated weekly news. If empty,
# storyline_templates.py provides deterministic fallback text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional template that allows per-guild OpenAI keys (advanced).
OPENAI_API_KEY_TEMPLATE=

# Auto-post Game-of-the-Week matchup previews on schedule ingest.
# Set to "false" to disable.
AUTO_POST_MATCHUP_PREVIEWS=true
